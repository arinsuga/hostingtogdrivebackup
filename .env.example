# MySQL Database Configuration
DB_HOST=localhost
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# Google Drive Configuration
GOOGLE_DRIVE_FOLDER_ID=your_folder_id_here

# Backup Paths
BACKUP_TEMP_DIR=/home/tmp/backup
APP_ROOT=/home/username/public_html

# Email Notification
ADMIN_EMAIL=arinsuga@gmail.com

# Logging
LOG_DIR=./logs
LOG_FILE=backup.log

# Backup Retention (days)
RETENTION_DAYS=30

# Compression Level (1-9, 6 recommended)
COMPRESSION_LEVEL=6
