# MySQL Database Configuration
DB_HOST=localhost
DB_USER=database_username
DB_PASSWORD=database_password

# Google Drive Configuration
GOOGLE_DRIVE_FOLDER_ID=/GO/TO/BACKUP/FOLDER

# Backup Paths
BACKUP_TEMP_DIR=temp
APP_ROOT=/home/[username]/public_html

# Email Notification
ADMIN_EMAIL=admin@email.com

# Logging
LOG_DIR=logs
LOG_FILE=backup.log

# Backup Retention (days)
RETENTION_DAYS=30

# Compression Level (1-9, 6 recommended)
COMPRESSION_LEVEL=6
